# CPA Document Intake — Production Environment Template
# Copy to `.env.production` (NEVER commit that file) and fill in partner-specific values.
# Then run: ./scripts/render-k8s-secrets.sh --env-file .env.production --key-vault <vault-name>
#
# All secret values stay in Azure Key Vault. This file is a CONFIGURATION reference
# showing what the application reads from env (and therefore what must exist in
# Key Vault). No real credentials belong here — only resource identifiers.

# =============================================================================
# Azure identity (workload identity — no secrets in env)
# =============================================================================
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000    # user-assigned managed identity client ID
AZURE_KEY_VAULT_URI=https://<vault-name>.vault.azure.net/

# =============================================================================
# Azure OpenAI
# Key (azure-openai-api-key) lives in Key Vault. Endpoints/deployments are not secret.
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://<openai-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# =============================================================================
# Microsoft Graph (for mailbox polling)
# =============================================================================
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_REDIRECT_URI=https://<intake-host>/auth/callback
# MS_GRAPH_CLIENT_SECRET lives in Key Vault

# =============================================================================
# PostgreSQL (Azure Database for PostgreSQL Flexible Server)
# =============================================================================
POSTGRES_HOST=<server>.postgres.database.azure.com
POSTGRES_DB=cpa_intake
POSTGRES_USER=cpa_admin
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=require
# POSTGRES_PASSWORD lives in Key Vault; managed-identity token auth preferred

# =============================================================================
# Redis (Azure Cache for Redis)
# =============================================================================
REDIS_HOST=<cache>.redis.cache.windows.net
REDIS_PORT=6380
REDIS_SSL_ENABLED=true
# REDIS_PASSWORD lives in Key Vault

# =============================================================================
# Object storage (Azure Blob via S3-compatible API)
# =============================================================================
MINIO_ENDPOINT=https://<storage>.blob.core.windows.net
MINIO_BUCKET_DOCS=cpa-docs
MINIO_BUCKET_AUDIT=cpa-audit
MINIO_USE_SSL=true
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY live in Key Vault

# =============================================================================
# Application configuration
# =============================================================================
APP_LOG_LEVEL=info
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
INGEST_POLL_INTERVAL_SECONDS=30
RATE_LIMIT_PER_MINUTE=200

# Decision flags — defaults match the 5 decision-driven GSD phases.
ENABLE_AUDIT_IMMUTABILITY=true      # Decision: 03-audit-immutability
ENABLE_IDEMPOTENCY=true             # Decision: 04-intake-idempotency
ENABLE_REVIEWER_WORKFLOW=true       # Decision: 05-reviewer-workflow

# =============================================================================
# Observability
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTEL_SERVICE_NAME=cpa-doc-intake
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.namespace=cpa-workflow-automation

APPINSIGHTS_INSTRUMENTATIONKEY=00000000-0000-0000-0000-000000000000   # from App Insights resource

# =============================================================================
# Feature flags (use sparingly — kill switches for production incidents)
# =============================================================================
FEATURE_LLM_FALLBACK=true          # if Azure OpenAI times out, fall back to heuristic router
FEATURE_QUEUE_REPLAY=true          # allow reviewer to replay a single document's pipeline

# =============================================================================
# Compliance
# =============================================================================
RETENTION_DAYS_DOCS=2555           # 7 years (IRS Pub 583 retention)
RETENTION_DAYS_AUDIT=2555          # 7 years (SOX / IRS retention)
AUDIT_HASH_ALGO=sha256